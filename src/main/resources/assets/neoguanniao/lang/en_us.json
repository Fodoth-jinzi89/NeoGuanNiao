  "gui.neoguanniao.bird_guide.title": "Bird Guide",
  "gui.neoguanniao.bird_guide.close": "Close",
  "gui.neoguanniao.bird_guide.species": "Birds",
  "gui.neoguanniao.bird_guide.scroll_hint": "Scroll for more notes",
